# ==========================================
# CONFIGURACION DEL ENTORNO
# ==========================================

# URL base del frontend (sin trailing slash)
# Local: http://localhost:8080
# Produccion: http://bqto.iujo.edu.ve/Socioeconomico
BASE_URL=http://localhost:8080

# URL base del backend API (con trailing slash)
# Local Docker: http://web:81/
# Produccion: http://bqto.iujo.edu.ve/Socioeconomico/backend/public/
API_BASE_URL=http://web:81/

APP_NAME=Formulario_Socioeconomico

# URL de la aplicacion (puede ser la misma que BASE_URL)
APP_URL=http://localhost:8080

# Timeout en segundos para peticiones a la API
API_TIMEOUT=30

# Tiempo de inactividad antes de cerrar sesion (segundos)
SESSION_TIMEOUT=300

# Segundos antes del timeout para mostrar advertencia
SESSION_WARNING_BEFORE=60
